{
  "name": "dashterm",
  "version": "0.1.0",
  "main": "index.js",
  "scripts": {
    "postinstall": "cd packages/server && npm install --no-audit --no-fund && npm run build && cd ../../cli && npm install --no-audit --no-fund && npm run build",
    "start": "expo start --web",
    "web": "expo start --web",
    "gateway:dev": "cd packages/server && DASHTERM_DATA_DIR=../../.dashterm-dev-data DASHTERM_DEV_CORS_ORIGIN=http://localhost:8081 npm run dev",
    "web:dev": "EXPO_PUBLIC_BACKEND=dashterm-native EXPO_PUBLIC_GATEWAY_URL=http://localhost:8765 expo start --web --port 8081 --clear",
    "dev": "concurrently -k -n gateway,web -c blue,green \"npm run gateway:dev\" \"npm run web:dev\"",
    "dashterm": "node cli/dist/index.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.80.0",
    "babel-preset-expo": "^54.0.7",
    "expo": "~54.0.34",
    "expo-auth-session": "~7.0.11",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-ascii-text": "^0.0.4",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "^4.1.5",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-super-grid": "^6.0.2",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1"
  },
  "private": true,
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/react": "~19.1.10",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "esbuild": "^0.27.0",
    "express": "^5.1.0",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
