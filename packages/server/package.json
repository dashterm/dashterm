{
  "name": "@dashterm/server",
  "version": "0.1.0",
  "private": true,
  "description": "Local gateway for the native (non-Docker) DashTerm install. Serves the API the web app talks to, persists state in SQLite, runs the custom-app compile step in-process.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts dev",
    "start": "node dist/cli.js start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^10.0.1",
    "@node-rs/argon2": "^1.8.3",
    "better-sqlite3": "^11.5.0",
    "esbuild": "^0.20.0",
    "fastify": "^4.28.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "tsx": "^4.19.0",
    "typescript": "~5.5.0"
  }
}
