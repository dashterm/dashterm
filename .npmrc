# React Native + Expo + reanimated have transient peer-dep mismatches that
# Expo's own install path (`expo install`) tolerates. Without this flag, a
# from-scratch `npm install` (no lockfile) fails on react-native@0.81 vs
# react-native-reanimated@4.4 wanting 0.83-0.86. The lockfile is the
# source of truth for the resolved versions; this just keeps npm from
# rejecting them at install time.
legacy-peer-deps=true
