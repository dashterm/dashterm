{
  "name": "@dashterm/cli",
  "version": "0.2.0",
  "description": "DashTerm CLI — boot the local gateway, manage users + AI providers, drive the autostart daemon.",
  "private": true,
  "bin": {
    "dashterm": "./dist/index.js"
  },
  "main": "dist/index.js",
