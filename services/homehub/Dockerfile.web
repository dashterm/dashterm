# Web bundle for the homehub.
#
# Context is the repo root (..). We do a two-stage build: install deps +
# expo export → web/, then ship the static output behind Caddy.

FROM node:20-alpine AS build
WORKDIR /app
RUN apk add --no-cache git
# Install: only what's needed for `expo export --platform web`. The
# repo is a single root package.json + per-package subfolders.
COPY package.json package-lock.json ./
# --ignore-scripts skips the root postinstall hook (which builds the CLI).
# The CLI isn't needed inside the web container — we only need npm deps
# to run `expo export --platform web`. Without --ignore-scripts the build
# fails because the cli/ directory isn't COPYed into the context until the
# step below.
RUN npm ci --no-audit --no-fund --ignore-scripts
COPY . ./

# These are the only knobs the web build needs to point at the right
# backend. Both are baked into the bundle at build time via Expo's
# EXPO_PUBLIC_* env var convention.
ARG EXPO_PUBLIC_BACKEND=supabase
ARG EXPO_PUBLIC_SUPABASE_URL
ARG EXPO_PUBLIC_SUPABASE_ANON_KEY
ARG EXPO_PUBLIC_COMPILE_URL=http://localhost:8089
ENV EXPO_PUBLIC_BACKEND=$EXPO_PUBLIC_BACKEND
ENV EXPO_PUBLIC_SUPABASE_URL=$EXPO_PUBLIC_SUPABASE_URL
ENV EXPO_PUBLIC_SUPABASE_ANON_KEY=$EXPO_PUBLIC_SUPABASE_ANON_KEY
ENV EXPO_PUBLIC_COMPILE_URL=$EXPO_PUBLIC_COMPILE_URL

RUN npx expo export --platform web --output-dir dist

FROM caddy:2.8-alpine
COPY services/homehub/Caddyfile /etc/caddy/Caddyfile
COPY --from=build /app/dist /srv
EXPOSE 80
