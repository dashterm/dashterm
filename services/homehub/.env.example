# DashTerm homehub — environment template.
#
# Copy to .env and fill in. The `dashterm homehub init` CLI command
# generates these for you (random secrets, sensible defaults).
#
# DO NOT commit your real .env. Keep it readable only by the docker
# user that runs the bundle (`chmod 600 .env`).

# ---------------------------------------------------------------------------
# Public URL — where the web app + API live from the user's browser.
# In a typical HomeLab install this is e.g. https://dashterm.lan or
# https://dashterm.example.com behind a reverse proxy. Leave the default
# for a single-host local install.
# ---------------------------------------------------------------------------
PUBLIC_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
POSTGRES_DB=dashterm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-32-random-chars-here-replace
POSTGRES_PORT=5432
# Host port — for psql/pg_dump from the host.
POSTGRES_PORT_EXPOSED=54322

# ---------------------------------------------------------------------------
# Secrets — replace ALL of these. The init command does this for you.
# JWT_SECRET must be 32+ chars. ANON_KEY / SERVICE_ROLE_KEY are signed JWTs
# (roles "anon" / "service_role") derived from JWT_SECRET.
# ---------------------------------------------------------------------------
JWT_SECRET=__replace_with_32_plus_random_chars__
ANON_KEY=__paste_anon_jwt_here__
SERVICE_ROLE_KEY=__paste_service_role_jwt_here__

# Realtime channel encryption / session keys.
REALTIME_ENC_KEY=__16_random_chars__
REALTIME_SECRET_KEY_BASE=__64_random_chars__

# ---------------------------------------------------------------------------
# Google OAuth — optional. Without these, email/password login still works
# (GoTrue's local provider). To enable Google sign-in, create OAuth client
# credentials in Google Cloud Console and paste them in.
# ---------------------------------------------------------------------------
GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_SECRET=

# ---------------------------------------------------------------------------
# Public ports — what's exposed on the host. Each service is reachable
# inside the docker network regardless of whether the host port is bound.
# ---------------------------------------------------------------------------
# API gateway (auth/rest/realtime/storage).
KONG_HTTP_PORT=8000
# DashTerm web frontend.
WEB_PORT=8082
# Custom-app compile server.
COMPILE_PORT=8089
# Supabase Studio admin UI (only published when the `dev` compose profile is on).
STUDIO_PORT=3001
