{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "index.js",
    "packages/**/*",
    "tests/**/*",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "playwright-report",
    "test-results",
    "cli",
    "services",
    "website",
    "packages/**/node_modules",
    "packages/**/dist"
  ]
}